{
  "junaidtech": {
    "base_url": "https://www.junaidtech.pk",
    "fetcher_type": "dynamic",
    "use_selenium": false,
    "selectors": {
      "card": "div.product-card-2",
      "title": "a.product-title",
      "link": "a.product-title",
      "price": "div.product-price",
      "load_more": "button.load-more-btn"
    },
